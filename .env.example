# Copy this file to .env and fill in your keys. Never commit .env.

# Roboflow (optional)
EXPO_PUBLIC_ROBOFLOW_KEY=your-roboflow-key-here
EXPO_PUBLIC_ROBOFLOW_MODEL=

# OpenAI — required for room scan analysis (get a key at platform.openai.com)
EXPO_PUBLIC_OPENAI_API_KEY=your-openai-key-here

# Optional
# EXPO_PUBLIC_HF_TOKEN=your-hf-token-here
