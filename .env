# ── Detection (Stage 1) ──────────────────────────────────────────────────────

# YOLOv8/v11 via Roboflow — fastest, fine-tunable on indoor/structural classes
# Get your key at roboflow.com → Settings → Roboflow API
EXPO_PUBLIC_ROBOFLOW_KEY=your-roboflow-key-here
# Format: "workspace/model-slug/version"  e.g. "haven-ai/indoor-hazards/3"
# Leave blank to use the default public indoor-objects model
EXPO_PUBLIC_ROBOFLOW_MODEL=

# OpenAI — used for room scan analysis (GPT-4o vision). Paste your key below:
